<%- include('partials/header') %>
<h2>Mon Profil</h2>

<div class="card" style="max-width: 400px;">
    <p><strong>Nom d'utilisateur :</strong> <%= user.username %></p>
    <p><strong>Email :</strong> <%= user.email %></p>
    <p><strong>Avatar actuel :</strong></p>
    <% if(user.profile_pic === 'default-profile.png') { %>
        <div style="width:100px; height:100px; background:#ccc; border-radius:50%; display:flex; align-items:center; justify-content:center;">Pas d'image</div>
    <% } else { %>
        <img src="/uploads/<%= user.profile_pic %>" class="profile-img" alt="Avatar">
    <% } %>

    <hr>
    <h4>Mettre à jour ma photo de profil</h4>
    <form action="/profile/upload" method="POST" enctype="multipart/form-data">
        <input type="file" name="profile_pic" accept="image/*" required>
        <button type="submit">Téléverser</button>
    </form>
</div>
</body>
</html>