<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Salles</title>
</head>
<body>
  <% include partials_header %>

  <h1>Liste des salles</h1>

  <h2>Recherche</h2>
  <form method="get" action="/rooms">
    <div>
      <label>Nom contient :</label>
      <input type="text" name="name" value="<%= filters.name || '' %>">
    </div>
    <div>
      <label>Capacité minimale :</label>
      <input type="number" name="min_capacity" value="<%= filters.min_capacity || '' %>">
    </div>
    <div>
      <label>Date :</label>
      <input type="date" name="date" value="<%= filters.date || '' %>">
    </div>
    <div>
      <label>Heure début :</label>
      <input type="time" name="start_time" value="<%= filters.start_time || '' %>">
    </div>
    <div>
      <label>Heure fin :</label>
      <input type="time" name="end_time" value="<%= filters.end_time || '' %>">
    </div>
    <button type="submit">Rechercher</button>
  </form>

  <h2>Résultats</h2>
  <ul>
    <% rooms.forEach(room => { %>
      <li>
        <strong><%= room.name %></strong> — capacité : <%= room.capacity %><br>
        <em><%= room.equipment %></em><br>
        <% if (room.photo) { %>
          <img src="<%= room.photo %>" alt="<%= room.name %>" style="max-width:200px;">
        <% } %><br>
        <% if (currentUser) { %>
          <a href="/reservations/new?room_id=<%= room.id %>">Réserver</a>
        <% } else { %>
          <a href="/login">Connectez-vous pour réserver</a>
        <% } %>
      </li>
    <% }) %>
  </ul>
</body>
</html>
