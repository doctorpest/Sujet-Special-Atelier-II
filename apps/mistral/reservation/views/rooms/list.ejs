<%- include('layout', { active: 'rooms' }) %>

<% block('body') %>
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-door-open"></i> Liste des salles disponibles</h1>
        <p>Trouvez la salle parfaite pour votre réunion</p>
    </div>
</div>

<div class="search-section">
    <div class="container">
        <form action="/rooms" method="GET" class="search-form">
            <div class="search-grid">
                <div class="form-group">
                    <label for="search"><i class="fas fa-search"></i> Rechercher par nom</label>
                    <input type="text" id="search" name="search" value="<%= search || '' %>" placeholder="Nom de la salle...">
                </div>
                <div class="form-group">
                    <label for="minCapacity"><i class="fas fa-users"></i> Capacité minimale</label>
                    <select id="minCapacity" name="minCapacity">
                        <option value="">Toutes les capacités</option>
                        <option value="4" <%= minCapacity === '4' ? 'selected' : '' %>>4 personnes</option>
                        <option value="8" <%= minCapacity === '8' ? 'selected' : '' %>>8 personnes</option>
                        <option value="10" <%= minCapacity === '10' ? 'selected' : '' %>>10 personnes</option>
                        <option value="20" <%= minCapacity === '20' ? 'selected' : '' %>>20 personnes</option>
                        <option value="50" <%= minCapacity === '50' ? 'selected' : '' %>>50 personnes</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="date"><i class="fas fa-calendar"></i> Date</label>
                    <input type="date" id="date" name="date" value="<%= date || '' %>" min="<%= new Date().toISOString().split('T')[0] %>">
                </div>
                <div class="form-group">
                    <label for="startTime"><i class="fas fa-clock"></i> Heure de début</label>
                    <select id="startTime" name="startTime">
                        <option value="">Heure de début</option>
                        <% for (let h = 8; h <= 18; h++) { %>
                            <option value="<%= h.toString().padStart(2, '0') %>:00" <%= startTime === `${h.toString().padStart(2, '0')}:00` ? 'selected' : '' %>>
                                <%= h.toString().padStart(2, '0') %>:00
                            </option>
                        <% } %>
                    </select>
                </div>
                <div class="form-group">
                    <label for="endTime"><i class="fas fa-clock"></i> Heure de fin</label>
                    <select id="endTime" name="endTime">
                        <option value="">Heure de fin</option>
                        <% for (let h = 9; h <= 19; h++) { %>
                            <option value="<%= h.toString().padStart(2, '0') %>:00" <%= endTime === `${h.toString().padStart(2, '0')}:00` ? 'selected' : '' %>>
                                <%= h.toString().padStart(2, '0') %>:00
                            </option>
                        <% } %>
                    </select>
                </div>
                <div class="form-group search-btn-group">
                    <label>&nbsp;</label>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Rechercher</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="rooms-section">
    <div class="container">
        <% if (rooms.length > 0) { %>
            <div class="rooms-grid">
                <% rooms.forEach(room => { %>
                    <div class="room-card <%= room.available ? 'available' : 'unavailable' %>">
                        <div class="room-image">
                            <% if (room.photo_url) { %>
                                <img src="<%= room.photo_url %>" alt="<%= room.name %>">
                            <% } else { %>
                                <div class="room-placeholder"><i class="fas fa-door-closed"></i></div>
                            <% } %>
                            <span class="room-status">
                                <% if (room.available) { %><i class="fas fa-check-circle"></i> Disponible<% } else { %><i class="fas fa-times-circle"></i> Indisponible<% } %>
                            </span>
                        </div>
                        <div class="room-info">
                            <h3><%= room.name %></h3>
                            <p class="room-description"><%= room.description || 'Aucune description' %></p>
                            <div class="room-details">
                                <div class="room-detail"><i class="fas fa-users"></i><span><%= room.capacity %> personnes</span></div>
                                <div class="room-detail"><i class="fas fa-tools"></i><span title="<%= room.equipment || 'Aucun équipement' %>">Équipement</span></div>
                            </div>
                            <div class="room-equipment">
                                <strong>Équipements:</strong>
                                <p><%= room.equipment || 'Aucun équipement spécifié' %></p>
                            </div>
                        </div>
                        <div class="room-actions">
                            <a href="/rooms/<%= room.id %>" class="btn btn-outline"><i class="fas fa-info-circle"></i> Détails</a>
                            <% if (user) { %>
                                <a href="/reservations/new?roomId=<%= room.id %>&date=<%= date || '' %>&startTime=<%= startTime || '' %>&endTime=<%= endTime || '' %>" class="btn btn-primary <%= room.available ? '' : 'disabled' %>">
                                    <i class="fas fa-calendar-plus"></i> Réserver
                                </a>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="no-results">
                <i class="fas fa-search"></i>
                <h3>Aucune salle trouvée</h3>
                <p>Essayez de modifier vos critères de recherche.</p>
                <a href="/rooms" class="btn btn-primary"><i class="fas fa-redo"></i> Réinitialiser</a>
            </div>
        <% } %>
    </div>
</div>
<% endblock %>