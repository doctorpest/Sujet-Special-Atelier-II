<%- layout('layout') %>
<h2>Inscription</h2>
<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
<form method="POST" action="/register">
  <div class="mb-3"><input name="username" placeholder="Nom d'utilisateur" class="form-control" required></div>
  <div class="mb-3"><input name="email" type="email" placeholder="Email" class="form-control" required></div>
  <div class="mb-3"><input name="password" type="password" placeholder="Mot de passe" class="form-control" required></div>
  <button type="submit" class="btn btn-success">S'inscrire</button>
</form>