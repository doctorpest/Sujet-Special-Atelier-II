<%- layout('layout') %>
<h2><%= room.name %></h2>
<div class="row">
  <div class="col-md-6">
    <% if (room.photo) { %>
      <img src="<%= room.photo %>" class="img-fluid" alt="<%= room.name %>">
    <% } else { %>
      <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 300px;">
        <span class="text-white">Aucune image</span>
      </div>
    <% } %>
  </div>
  <div class="col-md-6">
    <p><strong>Capacité :</strong> <%= room.capacity %> personnes</p>
    <p><strong>Équipements :</strong> <%= room.equipment || 'Aucun' %></p>

    <% if (currentUser) { %>
      <h4>Réserver cette salle</h4>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <form method="POST" action="/reservations">
        <input type="hidden" name="room_id" value="<%= room.id %>">
        <div class="mb-3"><label>Date</label><input type="date" name="date" class="form-control" required></div>
        <div class="mb-3"><label>Heure début</label><input type="time" name="start_time" class="form-control" required></div>
        <div class="mb-3"><label>Heure fin</label><input type="time" name="end_time" class="form-control" required></div>
        <button type="submit" class="btn btn-success">Réserver</button>
      </form>
    <% } else { %>
      <a href="/login" class="btn btn-warning">Connectez-vous pour réserver</a>
    <% } %>
  </div>
</div>