<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Salles disponibles — MeetRoom</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/nav', { active: 'rooms' }) %>
<%- include('../partials/flash') %>
<main>
  <div class="page-header">
    <div class="page-header-text">
      <h1>Nos salles de réunion</h1>
      <p><%= rooms.length %> salle<%= rooms.length > 1 ? 's' : '' %> disponible<%= rooms.length > 1 ? 's' : '' %></p>
    </div>
    <a href="/reservations/new" class="btn btn-primary">＋ Nouvelle réservation</a>
  </div>

  <!-- Search bar -->
  <div class="card" style="padding:20px; margin-bottom:24px;">
    <form method="GET" action="/rooms" style="display:grid; grid-template-columns:1fr auto auto auto auto; gap:12px; align-items:end;">
      <div>
        <label class="form-label">Rechercher par nom</label>
        <input type="text" name="q" class="form-control" placeholder="Horizon, Focus…" value="<%= query.q || '' %>">
      </div>
      <div>
        <label class="form-label">Capacité min.</label>
        <input type="number" name="capacity" class="form-control" style="width:110px;" placeholder="ex: 8" min="1" value="<%= query.capacity || '' %>">
      </div>
      <div>
        <label class="form-label">Date</label>
        <input type="date" name="date" class="form-control" style="width:150px;" value="<%= query.date || '' %>" min="<%= new Date().toISOString().split('T')[0] %>">
      </div>
      <div>
        <label class="form-label">De</label>
        <input type="time" name="start" class="form-control" style="width:110px;" value="<%= query.start || '' %>">
      </div>
      <div>
        <label class="form-label">À</label>
        <input type="time" name="end" class="form-control" style="width:110px;" value="<%= query.end || '' %>">
      </div>
      <button type="submit" class="btn btn-primary" style="margin-bottom:1px;">Rechercher</button>
      <% if (Object.keys(query).some(k => query[k])) { %>
        <a href="/rooms" class="btn btn-outline" style="margin-bottom:1px;">Effacer</a>
      <% } %>
    </form>
  </div>

  <% if (rooms.length === 0) { %>
    <div class="empty">
      <div class="empty-icon">🔍</div>
      <h3>Aucune salle trouvée</h3>
      <p>Essayez d'autres critères de recherche.</p>
      <a href="/rooms" class="btn btn-outline" style="margin-top:16px;">Voir toutes les salles</a>
    </div>
  <% } else { %>
    <div class="grid-3">
      <% rooms.forEach(room => { %>
        <div class="card room-card">
          <div class="room-img-wrap">
            <img src="<%= room.photo %>" alt="<%= room.name %>" class="room-img" loading="lazy">
            <div class="room-floor"><%= room.floor || '' %></div>
          </div>
          <div class="room-body">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
              <h2 class="room-name"><%= room.name %></h2>
              <span class="badge badge-gold">👥 <%= room.capacity %> pers.</span>
            </div>
            <p class="room-desc"><%= room.description || '' %></p>
            <div class="room-equip">
              <% room.equipment.split(',').forEach(eq => { %>
                <span class="equip-tag"><%=eq.trim()%></span>
              <% }) %>
            </div>
            <div class="room-actions">
              <a href="/rooms/<%= room.id %>" class="btn btn-outline btn-sm">Voir les détails</a>
              <a href="/reservations/new?room_id=<%= room.id %>" class="btn btn-primary btn-sm">Réserver</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<footer>© <%= new Date().getFullYear() %> MeetRoom — Plateforme de gestion des salles de réunion</footer>

<style>
  .room-card { overflow: hidden; transition: box-shadow .2s, transform .2s; }
  .room-card:hover { box-shadow: 0 8px 32px rgba(18,16,14,.12); transform: translateY(-2px); }
  .room-img-wrap { position: relative; height: 200px; overflow: hidden; background: var(--cream); }
  .room-img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
  .room-card:hover .room-img { transform: scale(1.04); }
  .room-floor { position: absolute; top: 12px; left: 12px; background: rgba(26,24,20,.75); color: #fff; padding: 3px 10px; border-radius: 20px; font-size: 11px; letter-spacing: .5px; backdrop-filter: blur(4px); }
  .room-body { padding: 20px; }
  .room-name { font-family: 'Cormorant Garamond', serif; font-size: 20px; font-weight: 600; }
  .room-desc { color: var(--muted); font-size: 13px; line-height: 1.5; margin: 8px 0 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .room-equip { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
  .equip-tag { background: var(--cream); color: var(--muted); padding: 3px 9px; border-radius: 4px; font-size: 11px; }
  .room-actions { display: flex; gap: 8px; }
</style>
</body>
</html>
